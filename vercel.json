{
  "buildCommand": "echo 'Using pre-built dist folder'",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps || echo 'Skipping install'",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
