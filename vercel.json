{
  "buildCommand": "npm run build || echo 'Build skipped - using static dist folder'",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps || true",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "public": true,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
